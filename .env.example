# ================================================================
# .env.example — Support & Incident Management System (ROOT)
# File ini adalah template untuk PRODUCTION (Docker Compose).
# Salin dan isi semua variabel:
#   cp .env.example .env
#   nano .env
#
# File .env ROOT ini adalah satu-satunya .env yang perlu diisi
# saat deploy production dengan Docker Compose.
# backend/.env dan frontend/.env hanya untuk development lokal.
# ================================================================

# ── Application ──────────────────────────────────────────────
NODE_ENV=production

# ── Organization ─────────────────────────────────────────────
# Nama organisasi & departemen yang tampil di portal
ORG_NAME=Nama Organisasi Anda
ORG_DEPARTMENT=IT Department

# ── Database (PostgreSQL) ─────────────────────────────────────
# Prisma connection string — dipakai backend & frontend
# Docker: host WAJIB "postgres" (service name di sis-network)
DATABASE_URL=postgresql://formbricks_user:formbricks_pass@postgres:5432/formbricks_tickets?schema=public

# Credentials DB individual (dipakai docker-entrypoint.sh & N8N)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=formbricks_tickets
DB_USER=formbricks_user
DB_PASSWORD=formbricks_pass

# ── Backend Port ──────────────────────────────────────────────
PORT=3000

# ── Frontend Port ─────────────────────────────────────────────
FRONTEND_PORT=3001
# URL portal Next.js (untuk redirect dari backend & link internal)
# Ganti dengan IP LAN server di production:
# NEXTAUTH_URL=http://192.168.x.x:3001
NEXTAUTH_URL=http://localhost:3001

# ── Admin Portal Auth ─────────────────────────────────────────
ADMIN_USERNAME=admin

# PILIH SALAH SATU cara set password:
#
# CARA 1 — Plaintext (mudah, cocok untuk internal/dev):
#   Isi ADMIN_PASSWORD, kosongkan ADMIN_PASSWORD_HASH
ADMIN_PASSWORD=Admin@IT2026
ADMIN_PASSWORD_HASH=

# CARA 2 — Bcrypt Hash (lebih aman untuk production):
#   1. Generate hash:
#      docker exec sis-backend node -e "require('bcryptjs').hash('Admin@IT2026',12).then(console.log)"
#      ATAU: node -e "require('bcryptjs').hash('Admin@IT2026',12).then(console.log)"
#   2. Isi ADMIN_PASSWORD_HASH dengan hasil hash ($2b$12$...)
#   3. Kosongkan ADMIN_PASSWORD
#   ADMIN_PASSWORD=
#   ADMIN_PASSWORD_HASH=$2b$12$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# PENTING: Jika keduanya diisi, ADMIN_PASSWORD_HASH yang dipakai.
# PENTING: Gunakan double quotes jika hash mengandung $ di Docker Compose.

# JWT Secret — boleh string apapun, asal KONSISTEN dan tidak berubah
# Ganti string ini dengan nilai unik di production!
JWT_SECRET=sis_jwt_secret_key_change_this_in_production

# ── Discord Bot ───────────────────────────────────────────────
# Dapatkan dari: https://discord.com/developers/applications
# Bot → Token (klik "Reset Token" jika belum ada)
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# ID Channel Discord tempat thread tiket akan dibuat
# Cara ambil: klik kanan channel → Copy Channel ID (Developer Mode harus aktif)
DISCORD_CHANNEL_ID=your_discord_channel_id_here

# ID Server (Guild) Discord
# Cara ambil: klik kanan nama server → Copy Server ID
DISCORD_GUILD_ID=your_discord_guild_id_here

# ── N8N Integration ───────────────────────────────────────────
# URL internal Docker — tidak perlu diubah
N8N_WEBHOOK_URL=http://n8n:5678/webhook/discord-activity
N8N_CHATBOT_WEBHOOK=http://n8n:5678/webhook/chatbot-qa

# API Key untuk autentikasi backend ↔ N8N ↔ frontend
# Bisa string apapun, asal sama di semua komponen
N8N_API_KEY=automation_ticketing01_incident02

# URL N8N yang bisa diakses dari BROWSER / LUAR Docker (bukan internal)
# WAJIB diisi dengan IP LAN server agar webhook N8N bisa diconfigure dari UI
# Contoh: N8N_WEBHOOK_BASE=http://192.168.1.100:5678
N8N_WEBHOOK_BASE=http://192.168.x.x:5678

# Kredensial login N8N dashboard
N8N_USER=admin
N8N_PASS=admin123

# ── SMTP Email ────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Gmail yang digunakan untuk kirim notifikasi
SMTP_USER=your.email@gmail.com

# Gmail App Password (BUKAN password akun Gmail biasa!)
# Cara buat: https://myaccount.google.com/apppasswords
# Aktifkan 2FA dulu, lalu buat App Password untuk "Mail"
SMTP_PASS=your_gmail_app_password_16_chars

# Nama pengirim yang tampil di email notifikasi
EMAIL_FROM=IT Support <your.email@gmail.com>

# ── AI — Groq ─────────────────────────────────────────────────
# Daftar gratis di: https://console.groq.com
# Digunakan untuk AI classification, summary, chatbot
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── Portal & Reports ──────────────────────────────────────────
# URL backend yang bisa diakses dari LAN (untuk link laporan di email/Discord)
# Jika kosong → auto-detect IP dari /proc/net/fib_trie (DIREKOMENDASIKAN)
# Override manual jika auto-detect salah: PORTAL_URL=http://192.168.1.100:3000
PORTAL_URL=
HOST_IP=

# Direktori output HTML incident reports (di dalam container)
# Tidak perlu diubah — dipetakan ke Docker volume reports_data
PDF_OUTPUT_DIR=/app/public/reports

# Backend self-call URL (untuk !chatbot-stats)
# Docker: otomatis http://backend:3000 — tidak perlu diubah
# Override manual jika diperlukan: BACKEND_SELF_URL=http://192.168.x.x:3000
BACKEND_SELF_URL=

# ── Ngrok (tunnel Formbricks → Backend) ──────────────────────
# Diperlukan jika Formbricks di cloud dan server di LAN perusahaan.
# Dapatkan token: https://dashboard.ngrok.com/get-started/your-authtoken
#
# Setelah start, ambil URL publik:
#   docker logs sis-ngrok 2>&1 | grep -i url
#   atau buka: http://SERVER_IP:4040
#
# Set URL ini di Formbricks:
#   Settings → Integrations → Webhooks → Add Webhook
#   URL: https://xxxx.ngrok-free.app/webhook/formbricks
NGROK_AUTHTOKEN=your_ngrok_authtoken_here

# ── Formbricks Form IDs ───────────────────────────────────────
# ID form Formbricks untuk tiket Support dan Incident.
# Dapatkan dari URL saat buka survey: .../surveys/ID_INI/...
# Jika kosong → gunakan default hardcoded di backend/src/config/index.js
FORM_ID_TICKETING=your_formbricks_ticketing_form_id
FORM_ID_INCIDENT=your_formbricks_incident_form_id