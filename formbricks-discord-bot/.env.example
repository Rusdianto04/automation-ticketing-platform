# ================================================================
# .env вЂ” Support & Incident System (Monorepo)
# Salin ke .env dan isi semua variabel yang diperlukan:
#   cp .env.example .env && nano .env
# ================================================================

# в”Ђв”Ђ Application в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
NODE_ENV=production

# в”Ђв”Ђ Organization в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
ORG_NAME=SEAMOLEC
ORG_DEPARTMENT=IT Department

# в”Ђв”Ђ Database (PostgreSQL) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Prisma (dipakai backend & frontend)
DATABASE_URL=postgresql://formbricks_user:formbricks_pass@postgres:5432/formbricks_tickets?schema=public

# Individual (dipakai docker-entrypoint.sh dan N8N)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=formbricks_tickets
DB_USER=formbricks_user
DB_PASSWORD=formbricks_pass

# в”Ђв”Ђ Backend (Express + Discord Bot) вЂ” port 3000 в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
PORT=3000

# в”Ђв”Ђ Frontend (Next.js Portal) вЂ” port 3001 в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
FRONTEND_PORT=3001
# URL portal Next.js (untuk redirect dari backend & link internal)
NEXTAUTH_URL=http://localhost:3001

# в”Ђв”Ђ Admin Portal Auth в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
ADMIN_USERNAME=admin

# в”Ђв”Ђ PILIH SALAH SATU cara set password berikut: в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
#
# CARA 1 (Mudah вЂ” plaintext, cocok untuk dev/internal):
#   Isi ADMIN_PASSWORD dengan password yang diinginkan.
#   Kosongkan ADMIN_PASSWORD_HASH (atau hapus baris-nya).
ADMIN_PASSWORD=Admin@IT2026
ADMIN_PASSWORD_HASH=
#
# CARA 2 (Production вЂ” bcrypt hash):
#   1. Generate hash dulu:
#      docker exec sis-backend node -e "require('bcryptjs').hash('Admin@IT2026',12).then(console.log)"
#      ATAU: node -e "require('bcryptjs').hash('Admin@IT2026',12).then(console.log)"
#   2. Isi ADMIN_PASSWORD_HASH dengan hasil hash (dimulai dari $2b$...)
#   3. Kosongkan ADMIN_PASSWORD
#   Contoh:
#   ADMIN_PASSWORD=
#   ADMIN_PASSWORD_HASH=$2b$12$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# PENTING: Jika keduanya diisi, ADMIN_PASSWORD_HASH yang dipakai.
# в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

# JWT Secret вЂ” boleh diganti string apapun, asal konsisten
JWT_SECRET=sis_jwt_secret_key_2026

# в”Ђв”Ђ Discord Bot в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_CHANNEL_ID=your_discord_channel_id_here
DISCORD_GUILD_ID=your_discord_guild_id_here

# в”Ђв”Ђ N8N Integration в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# N8N_WEBHOOK_URL & N8N_CHATBOT_WEBHOOK: internal Docker URL (tidak perlu diubah)
N8N_WEBHOOK_URL=http://n8n:5678/webhook/discord-activity
N8N_CHATBOT_WEBHOOK=http://n8n:5678/webhook/chatbot-qa
N8N_API_KEY=automation_ticketing01_incident02
# N8N_WEBHOOK_BASE: URL N8N yang bisa diakses dari BROWSER/LUAR Docker
# Ini digunakan sebagai base URL webhook N8N yang tampil di UI N8N
# WAJIB diisi dengan IP LAN server, contoh: http://192.168.1.100:5678
# Jika kosong в†’ default http://n8n:5678 (internal saja, tidak bisa dari luar)
N8N_WEBHOOK_BASE=http://192.168.x.x:5678
N8N_USER=admin
N8N_PASS=admin123

# в”Ђв”Ђ SMTP Email в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
# Gmail App Password (bukan password akun): https://myaccount.google.com/apppasswords
SMTP_PASS=your_gmail_app_password_16_chars
EMAIL_FROM=IT Support <your.email@gmail.com>

# в”Ђв”Ђ AI (Groq) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Daftar gratis: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# в”Ђв”Ђ Portal & Reports в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# URL backend yang dapat diakses dari LAN perusahaan.
# Jika kosong в†’ auto-detect IP server (via /proc/net/fib_trie)
# Contoh: PORTAL_URL=http://192.168.1.100:3000
PORTAL_URL=
HOST_IP=
# Backend self-call URL untuk !chatbot-stats (otomatis http://backend:3000 di Docker)
# Isi jika perlu override manual: BACKEND_SELF_URL=http://192.168.x.x:3000
BACKEND_SELF_URL=
PDF_OUTPUT_DIR=/app/public/reports

# в”Ђв”Ђ Ngrok (opsional вЂ” public tunnel dari Formbricks ke backend) в”Ђв”Ђ
# Diperlukan jika Formbricks dihosting di cloud dan server di LAN.
# Dapatkan token: https://dashboard.ngrok.com/get-started/your-authtoken
# Cara aktifkan: docker compose --profile ngrok up -d
# URL webhook Formbricks = https://xxxx.ngrok-free.app/webhook/formbricks
NGROK_AUTHTOKEN=your_ngrok_authtoken_here

# в”Ђв”Ђ Formbricks Form IDs в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Dapatkan dari Formbricks: buka survey в†’ lihat URL в†’ salin ID-nya
# Contoh URL: https://app.formbricks.com/environments/xxx/surveys/ID_INI/...
# Jika kosong в†’ fallback ke default hardcoded di config/index.js
FORM_ID_TICKETING=zcp7cbqqrtavbyd6wwkmk2vx
FORM_ID_INCIDENT=cmiobkjfm2piqad012scz1yxf