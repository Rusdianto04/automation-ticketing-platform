# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Environment Variables Template
# Copy ke .env dan isi semua nilai yang diperlukan
#
# cp .env.example .env
# nano .env
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Organization ─────────────────────────────────────────────────────────────
ORG_NAME=SEAMOLEC
ORG_DEPARTMENT=IT Department

# ===============================================================
# PostgreSQL Database Configuration
# ===============================================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_DIALECT=postgres

# PostgreSQL untuk N8N
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# ── Database (Prisma) ─────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Untuk Docker Compose: HOST = nama service postgres (default: "postgres")
DATABASE_URL=postgresql:

# ── Discord ──────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
DISCORD_GUILD_ID=

# ── N8N Integration ──────────────────────────────────────────────────────────
N8N_WEBHOOK_URL=http://n8n:5678/webhook/discord-activity
N8N_CHATBOT_WEBHOOK=http://n8n:5678/webhook/chatbot-qa
N8N_API_KEY=
N8N_USER=
N8N_PASS=
N8N_WEBHOOK_BASE=http://n8n:5678

# ── SMTP Email ───────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# ── AI (Groq) ────────────────────────────────────────────────────────────────
# Daftar gratis di: https://console.groq.com
GROQ_API_KEY=

# ── Portal URL (Laporan HTML) ─────────────────────────────────────────────────
# URL yang dapat diakses dari seluruh jaringan LAN perusahaan
# Jika kosong: auto-detect IP LAN server
# Contoh: http://192.168.1.100:3000  atau  http://portal.company.local
HOST_IP=
PORTAL_URL=   

# ── Ngrok (digunakan docker-compose.yml untuk Formbricks webhook) ─────────────
# Buat token di: https://dashboard.ngrok.com
# Juga update di ngrok.yml → authtoken
NGROK_AUTHTOKEN=
