# ================================================================
# .env.example — SIS Backend (backend/)
#
# File ini adalah template untuk development lokal.
# Di production Docker, gunakan .env di ROOT monorepo
# (sejajar dengan docker-compose.yml).
#
# Struktur monorepo:
#   formbricks-discord-bot/
#   ├── .env                ← ROOT .env (dibaca docker-compose)
#   ├── docker-compose.yml
#   ├── backend/            ← folder ini
#   └── frontend/
# ================================================================

# ── App ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Organization ─────────────────────────────────────────────────
ORG_NAME=SEAMOLEC
ORG_DEPARTMENT=IT Department

# ── Database ──────────────────────────────────────────────────────
# Docker: host = "postgres" (service name di sis-network)
# Dev   : host = "localhost"
DATABASE_URL=postgresql://formbricks_user:formbricks_pass@localhost:5432/formbricks_tickets?schema=public
DB_HOST=localhost
DB_PORT=5432
DB_NAME=formbricks_tickets
DB_USER=formbricks_user
DB_PASSWORD=formbricks_pass

# ── Discord ───────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_CHANNEL_ID=your_discord_channel_id_here
DISCORD_GUILD_ID=your_discord_guild_id_here

# ── N8N Integration ───────────────────────────────────────────────
# Docker: http://n8n:5678  (service name di sis-network)
# Dev   : http://localhost:5678
N8N_WEBHOOK_URL=http://localhost:5678/webhook/discord-activity
N8N_CHATBOT_WEBHOOK=http://localhost:5678/webhook/chatbot-qa
N8N_API_KEY=automation_ticketing01_incident02

# ── SMTP ──────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM=IT Support <your.email@gmail.com>

# ── AI (Groq) ─────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── Formbricks Form IDs ───────────────────────────────────────────
# Sesuaikan jika Form ID Formbricks Anda berbeda.
# docker-compose inject via: FORM_ID_TICKETING & FORM_ID_INCIDENT
FORM_ID_TICKETING=zcp7cbqqrtavbyd6wwkmk2vx
FORM_ID_INCIDENT=cmiobkjfm2piqad012scz1yxf

# ── Portal / Reports ──────────────────────────────────────────────
# PORTAL_URL: URL publik backend yang bisa diakses dari LAN
#   - Kosongkan = auto-detect (direkomendasikan)
#   - Manual: http://192.168.x.x:3000
PORTAL_URL=
HOST_IP=
PDF_OUTPUT_DIR=./public/reports

# ── Frontend (Next.js) ────────────────────────────────────────────
# Docker: http://frontend:3001  (service name di sis-network)
# Dev   : http://localhost:3001
FRONTEND_URL=http://localhost:3001
FRONTEND_PORT=3001

# ── Backend Self-Call ─────────────────────────────────────────────
# Digunakan oleh !chatbot-stats untuk memanggil /api/chatbot/stats
# Docker: otomatis http://backend:3000 (service name sis-network)
# Dev   : otomatis http://localhost:3000
# Override manual jika diperlukan:
BACKEND_SELF_URL=