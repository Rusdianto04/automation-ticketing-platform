{
  "name": "sis-backend",
  "version": "5.0.0",
  "description": "Support & Incident System — Backend (Discord Bot + Express API)",
  "main": "index.js",
  "scripts": {
    "start":       "node index.js",
    "dev":         "nodemon --watch src --watch index.js index.js",
    "migrate":     "npx prisma migrate deploy",
    "migrate:dev": "npx prisma migrate dev",
    "generate":    "npx prisma generate",
    "db:push":     "npx prisma db push",
    "studio":      "npx prisma studio"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "axios":          "^1.7.2",
    "body-parser":    "^1.20.2",
    "discord.js":     "^14.16.3",
    "dotenv":         "^16.4.5",
    "express":        "^4.19.2",
    "nodemailer":     "^6.9.14",
    "pg":             "^8.12.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "prisma":  "^5.14.0"
  }
}