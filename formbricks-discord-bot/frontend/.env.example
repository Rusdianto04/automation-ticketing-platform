# ================================================================
# .env.example — SIS Frontend (frontend/)
# Setup dev lokal:
#   cp frontend/.env.example frontend/.env
#   nano frontend/.env
# ================================================================

# ── Database ──────────────────────────────────────────────────
# Dev lokal: host = "localhost" (bukan "postgres")
# Docker:    host = "postgres"  (service name di sis-network)
DATABASE_URL=postgresql://formbricks_user:formbricks_pass@localhost:5432/formbricks_tickets?schema=public

# ── Organization ─────────────────────────────────────────────
ORG_NAME=Nama Organisasi Anda
ORG_DEPARTMENT=IT Department

# ── Admin Portal Auth ─────────────────────────────────────────
ADMIN_USERNAME=admin

# PILIH SALAH SATU cara set password:
#
# CARA 1 — Plaintext (mudah, cocok untuk dev/internal):
#   Isi ADMIN_PASSWORD, kosongkan ADMIN_PASSWORD_HASH
ADMIN_PASSWORD=Admin@IT2026
ADMIN_PASSWORD_HASH=

# CARA 2 — Bcrypt Hash (lebih aman untuk production):
#   1. Generate hash:
#      node -e "require('bcryptjs').hash('Admin@IT2026',12).then(console.log)"
#   2. Isi ADMIN_PASSWORD_HASH dengan hasil hash ($2b$12$...)
#   3. Kosongkan ADMIN_PASSWORD
#   ADMIN_PASSWORD=
#   ADMIN_PASSWORD_HASH=$2b$12$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# PENTING: Jika keduanya diisi, ADMIN_PASSWORD_HASH yang dipakai.

# JWT Secret — harus SAMA dengan yang di ROOT .env
# Ganti dengan string unik di production!
JWT_SECRET=sis_jwt_secret_key_change_this_in_production

# ── App ───────────────────────────────────────────────────────
# Dev lokal: http://localhost:3001
# Docker / Production: http://SERVER_IP:3001
NEXTAUTH_URL=http://localhost:3001
NODE_ENV=development