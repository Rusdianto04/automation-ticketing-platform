# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/formbricks_db"

# ─── Organization ─────────────────────────────────────────────────────────────
ORG_NAME="IT Support Division"
ORG_DEPARTMENT="IT Infrastructure"

# ─── Admin Auth ───────────────────────────────────────────────────────────────
# Username admin (default: admin)
ADMIN_USERNAME="admin"

# Password hash — generate dengan: node -e "const b=require('bcryptjs');b.hash('Admin@IT2024',12).then(h=>console.log(h))"
# Default password (dev only): Admin@IT2024
ADMIN_PASSWORD_HASH=""

# JWT Secret — WAJIB diganti di production!
JWT_SECRET="your_very_secret_jwt_key_change_me_in_production_2024"

# ─── App ─────────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3001"
NODE_ENV="development"
