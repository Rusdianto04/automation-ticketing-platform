{
  "name": "support-incident-system",
  "version": "1.0.0",
  "private": true,
  "description": "Support & Incident Management System — Monorepo (Backend + Frontend)",
  "scripts": {
    "dev":            "concurrently -n backend,frontend -c cyan,magenta \"cd apps/backend && npm run dev\" \"cd apps/frontend && npm run dev\"",
    "dev:backend":    "cd apps/backend && npm run dev",
    "dev:frontend":   "cd apps/frontend && npm run dev",
    "install:all":    "cd apps/backend && npm install && cd ../frontend && npm install",
    "build:frontend": "cd apps/frontend && npm run build",
    "generate":       "cd apps/backend && npm run generate",
    "prisma:studio":  "cd apps/backend && npx prisma studio",
    "docker:up":      "docker compose -f docker-compose.prod.yml up -d --build",
    "docker:dev":     "docker compose -f docker-compose.dev.yml up -d --build",
    "docker:down":    "docker compose -f docker-compose.prod.yml down",
    "docker:logs":    "docker compose -f docker-compose.prod.yml logs -f",
    "docker:restart": "docker compose -f docker-compose.prod.yml restart"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm":  ">=9.0.0"
  }
}
