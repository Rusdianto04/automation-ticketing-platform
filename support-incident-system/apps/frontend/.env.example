# =============================================================================
# apps/frontend/.env.example — Frontend Service (Next.js Portal)
#
# Salin: cp apps/frontend/.env.example apps/frontend/.env
# =============================================================================

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=production
ORG_NAME=Nama Organisasi Anda
ORG_DEPARTMENT=IT Department

# ── Database ──────────────────────────────────────────────────────────────────
# Production (Docker): host = postgres
# Development lokal:   host = localhost
DATABASE_URL=postgresql://formbricks_user:formbricks_pass@postgres:5432/formbricks_tickets?schema=public

# ── Admin Portal Auth ─────────────────────────────────────────────────────────
ADMIN_USERNAME=admin

# CARA 1 — Plaintext (mudah, untuk internal/staging):
ADMIN_PASSWORD=Admin@IT2026
ADMIN_PASSWORD_HASH=

# CARA 2 — Bcrypt Hash (production, lebih aman):
#   docker exec sis-backend node -e "require('bcryptjs').hash('AdminBaru',12).then(console.log)"
#   Salin output ke ADMIN_PASSWORD_HASH, kosongkan ADMIN_PASSWORD
# ADMIN_PASSWORD=
# ADMIN_PASSWORD_HASH=$2b$12$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# JWT Secret — ganti dengan string unik dan panjang
# Generate: openssl rand -hex 32
JWT_SECRET=ganti_dengan_string_rahasia_unik_production

# ── N8N API Key ───────────────────────────────────────────────────────────────
# Harus sama dengan N8N_API_KEY di .env root dan apps/backend/.env
N8N_API_KEY=automation_ticketing01_incident02

# ── Frontend URL ──────────────────────────────────────────────────────────────
# Wajib diisi dengan IP/domain server untuk production
# Via nginx port 80:   NEXTAUTH_URL=http://192.168.1.100
# Langsung port 3001:  NEXTAUTH_URL=http://192.168.1.100:3001
NEXTAUTH_URL=http://192.168.x.x:3001