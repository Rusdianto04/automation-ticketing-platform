# =============================================================================
# apps/backend/.env.example — Backend Service
#
# Salin: cp apps/backend/.env.example apps/backend/.env
# =============================================================================

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=production
ORG_NAME=Nama Organisasi Anda
ORG_DEPARTMENT=IT Department

# ── Database ──────────────────────────────────────────────────────────────────
# Production (Docker): host = postgres
# Development lokal:   host = localhost
DATABASE_URL=postgresql://formbricks_user:formbricks_pass@postgres:5432/formbricks_tickets?schema=public
DB_HOST=postgres
DB_PORT=5432
DB_NAME=formbricks_tickets
DB_USER=formbricks_user
DB_PASSWORD=formbricks_pass

# ── Discord Bot ───────────────────────────────────────────────────────────────
# https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_CHANNEL_ID=your_discord_channel_id_here
DISCORD_GUILD_ID=your_discord_guild_id_here

# ── N8N Integration ───────────────────────────────────────────────────────────
# URL internal Docker (gunakan service name, bukan IP)
N8N_WEBHOOK_URL=http://n8n:5678/webhook/discord-activity
N8N_CHATBOT_WEBHOOK=http://n8n:5678/webhook/chatbot-qa
N8N_INCIDENT_WEBHOOK=http://n8n:5678/webhook/incident-event
# Harus sama dengan N8N_API_KEY di .env root
N8N_API_KEY=automation_ticketing01_incident02

# ── SMTP Email ────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
# Gmail App Password: https://myaccount.google.com/apppasswords
SMTP_PASS=your_gmail_app_password_16_chars
EMAIL_FROM=IT Support <your.email@gmail.com>

# ── AI — Groq ─────────────────────────────────────────────────────────────────
# https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── Formbricks ────────────────────────────────────────────────────────────────
# Ambil Form ID dari URL survey di Formbricks dashboard
FORM_ID_TICKETING=your_formbricks_ticketing_form_id
FORM_ID_INCIDENT=your_formbricks_incident_form_id

# Field mapping: "questionId:Label,questionId2:Label2,..."
# Lihat log backend untuk mendapatkan question ID: docker logs sis-backend | grep "ID→Label"
FORMBRICKS_TICKETING_FIELD_MAP=
FORMBRICKS_INCIDENT_FIELD_MAP=

# ── Portal & Reports ──────────────────────────────────────────────────────────
# Kosongkan = auto-detect IP. Override jika salah: PORTAL_URL=http://192.168.1.100
PORTAL_URL=
HOST_IP=
PDF_OUTPUT_DIR=/app/public/reports

# ── Ngrok (opsional — hanya jika Formbricks cloud + server LAN) ──────────────
# https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your_ngrok_authtoken_here