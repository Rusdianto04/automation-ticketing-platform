# ================================================================
# .env.example — SIS Backend (backend/)
# Setup dev lokal:
#   cp backend/.env.example backend/.env
#   nano backend/.env
# ================================================================

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Organization ─────────────────────────────────────────────
ORG_NAME=Nama Organisasi Anda
ORG_DEPARTMENT=IT Department

# ── Database ──────────────────────────────────────────────────
# Dev lokal: host = "localhost" (bukan "postgres")
# Docker:    host = "postgres"  (service name di sis-network)
DATABASE_URL=postgresql://formbricks_user:formbricks_pass@localhost:5432/formbricks_tickets?schema=public
DB_HOST=localhost
DB_PORT=5432
DB_NAME=formbricks_tickets
DB_USER=formbricks_user
DB_PASSWORD=formbricks_pass

# ── Discord Bot ───────────────────────────────────────────────
# Dapatkan dari: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_CHANNEL_ID=your_discord_channel_id_here
DISCORD_GUILD_ID=your_discord_guild_id_here

# ── N8N Integration ───────────────────────────────────────────
# Dev lokal: gunakan localhost
# Docker:    gunakan service name (http://n8n:5678)
N8N_WEBHOOK_URL=http://localhost:5678/webhook/discord-activity
N8N_CHATBOT_WEBHOOK=http://localhost:5678/webhook/chatbot-qa
N8N_API_KEY=automation_ticketing01_incident02

# ── SMTP Email ────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
# Gmail App Password: https://myaccount.google.com/apppasswords
SMTP_PASS=your_gmail_app_password_16_chars
EMAIL_FROM=IT Support <your.email@gmail.com>

# ── AI — Groq ─────────────────────────────────────────────────
# Daftar gratis: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── Formbricks Form IDs ───────────────────────────────────────
# Dapatkan dari URL survey Formbricks Anda
FORM_ID_TICKETING=your_formbricks_ticketing_form_id
FORM_ID_INCIDENT=your_formbricks_incident_form_id

# ── Portal & Reports ──────────────────────────────────────────
# Kosongkan = auto-detect IP (direkomendasikan)
# Manual: PORTAL_URL=http://192.168.x.x:3000
PORTAL_URL=
HOST_IP=
PDF_OUTPUT_DIR=./public/reports

# ── Frontend (Next.js) ────────────────────────────────────────
# Dev lokal: http://localhost:3001
# Docker:    http://frontend:3001
FRONTEND_URL=http://localhost:3001
FRONTEND_PORT=3001

# ── Backend Self-Call ─────────────────────────────────────────
# Dev lokal: kosongkan (otomatis http://localhost:3000)
# Docker:    otomatis http://backend:3000
# Override: BACKEND_SELF_URL=http://192.168.x.x:3000
BACKEND_SELF_URL=