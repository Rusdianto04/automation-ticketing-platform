# ================================================================
# .env.example — Support & Incident System
# ================================================================
#
# File ini adalah TEMPLATE untuk konfigurasi production (Docker Compose).
#
# CARA PAKAI:
#   cp .env.example .env
#   nano .env   ← isi semua variabel yang diperlukan
#
# CATATAN:
#   • File .env ROOT ini adalah satu-satunya .env yang perlu diisi
#     saat deploy dengan Docker Compose (dev maupun production).
#   • apps/backend/.env dan apps/frontend/.env hanya untuk
#     development lokal tanpa Docker.
# ================================================================

# ── Application ──────────────────────────────────────────────────────────────
# Mode aplikasi: "production" atau "development"
# Gunakan "development" untuk hot-reload backend (docker-compose.dev.yml)
NODE_ENV=production

# ── Organization ─────────────────────────────────────────────────────────────
# Nama organisasi & departemen yang tampil di header portal
# Contoh: SEAMOLEC, PT. Maju Bersama, Universitas X
ORG_NAME=Nama Organisasi Anda
# Departemen yang ditampilkan di bawah nama organisasi
ORG_DEPARTMENT=IT Department


# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public
#
# Docker: HOST wajib "postgres" (service name di docker-compose, bukan IP)
# Development lokal (tanpa Docker): gunakan "localhost"
#
# Contoh production (Docker):
#   DATABASE_URL=postgresql://formbricks_user:formbricks_pass@postgres:5432/formbricks_tickets?schema=public
# Contoh development lokal:
#   DATABASE_URL=postgresql://formbricks_user:formbricks_pass@localhost:5433/formbricks_tickets?schema=public
DATABASE_URL=postgresql://formbricks_user:formbricks_pass@postgres:5432/formbricks_tickets?schema=public

# Credentials database individual
# Digunakan oleh docker-entrypoint.sh (Prisma migrate) dan N8N
DB_HOST=postgres
DB_PORT=5432
DB_NAME=formbricks_tickets
DB_USER=formbricks_user
DB_PASSWORD=formbricks_pass

# ── Backend Port ──────────────────────────────────────────────────────────────
# Port Express.js API + Discord Bot
# Jangan ganti jika tidak diperlukan (sudah dikonfigurasi di docker-compose)
PORT=3000

# ── Frontend Port ─────────────────────────────────────────────────────────────
# Port Next.js portal
FRONTEND_PORT=3001

# URL frontend yang diakses dari browser
# WAJIB diisi dengan IP server jika production di LAN
# Contoh: NEXTAUTH_URL=http://192.168.25.64:3001
# Biarkan localhost untuk development
NEXTAUTH_URL=http://localhost:3001


# ── Admin Portal Authentication ───────────────────────────────────────────────
# Username untuk login ke portal admin (/admin)
ADMIN_USERNAME=admin

# ── CARA SET PASSWORD ADMIN ──────────────────────────────────────────────────
#
# CARA 1 — Plaintext (cocok untuk internal/dev):
#   Isi ADMIN_PASSWORD, kosongkan ADMIN_PASSWORD_HASH
#   Sistem akan otomatis hash saat pertama login
----
# CARA 2 — Bcrypt Hash (lebih aman untuk production):
#   1. Generate hash dengan perintah berikut:
#      docker exec sis-backend node -e "require('bcryptjs').hash('PasswordBaru',12).then(console.log)"
#      ATAU (tanpa Docker):
#      node -e "require('bcryptjs').hash('PasswordBaru',12).then(console.log)"
#   2. Salin output ($2b$12$...) ke ADMIN_PASSWORD_HASH
#   3. Kosongkan ADMIN_PASSWORD
----
# PENTING: Jika KEDUANYA diisi, ADMIN_PASSWORD_HASH yang dipakai.
# PENTING: Gunakan double quotes jika hash mengandung $ di shell.
ADMIN_PASSWORD=Admin
ADMIN_PASSWORD_HASH=$2b$12$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Secret key untuk JWT session (token login admin)
# Ganti dengan string acak yang panjang dan unik di production!
# Generate: openssl rand -hex 32
JWT_SECRET=ganti_dengan_string_rahasia_yang_panjang_dan_unik_di_production


# ── Discord Bot ───────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_CHANNEL_ID=your_discord_channel_id_here
DISCORD_GUILD_ID=your_discord_guild_id_here


# ── N8N Workflow Automation ───────────────────────────────────────────────────
# URL webhook N8N untuk trigger dari backend
# Nilai ini adalah URL internal Docker — tidak perlu diubah
N8N_WEBHOOK_URL=http://n8n:5678/webhook/discord-activity
N8N_CHATBOT_WEBHOOK=http://n8n:5678/webhook/chatbot-qa
N8N_INCIDENT_WEBHOOK=http://n8n:5678/webhook/incident-event

# API Key untuk autentikasi backend ↔ N8N ↔ Frontend
# Nilai ini harus SAMA di semua komponen
# Boleh diganti dengan string apapun, asal konsisten
N8N_API_KEY=automation_ticketing01_incident02

# URL N8N yang bisa diakses dari BROWSER (bukan URL internal Docker)
# Digunakan untuk konfigurasi webhook di N8N dashboard
# WAJIB diisi dengan IP server untuk production
# Contoh: N8N_WEBHOOK_BASE=http://192.168.25.64:5678
# Script start.sh akan auto-detect jika dikosongkan
N8N_WEBHOOK_BASE=

# Kredensial login N8N dashboard
N8N_USER=admin
N8N_PASS=admin123


# ── SMTP Email ────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Alamat Gmail yang digunakan untuk mengirim notifikasi
SMTP_USER=your.email@gmail.com

# Gmail App Password (16 karakter, BUKAN password akun Gmail biasa!)
SMTP_PASS=your_gmail_app_password_16_chars

# Nama pengirim yang tampil di email
# Format: "Nama Pengirim <email@domain.com>"
EMAIL_FROM=IT Support <your.email@gmail.com>


# ── AI — Groq ─────────────────────────────────────────────────────────────────
# API key untuk Groq AI — digunakan untuk:
#   - AI classification tiket
#   - Auto-summary tiket
#   - Smart recommendation solusi
#   - Discord AI chatbot

GROQ_API_KEY=gsk_your_groq_api_key_here


# ── Portal & Reports ──────────────────────────────────────────────────────────
# URL backend yang bisa diakses dari LAN
# Digunakan untuk link laporan di email & Discord message
#
# Jika dikosongkan → backend akan auto-detect IP server dari /proc/net/fib_trie
# Override manual jika auto-detect salah:
# Contoh: PORTAL_URL=http://192.168.25.64:3000
PORTAL_URL=

# IP server (opsional — digunakan oleh start.sh untuk auto-inject)
# Jika dikosongkan → start.sh akan auto-detect
HOST_IP=

# Direktori output laporan insiden HTML (di dalam container)
# Tidak perlu diubah — dipetakan ke Docker volume sis_reports_data
PDF_OUTPUT_DIR=/app/public/reports

# URL backend untuk self-call (chatbot stats, health check internal)
# Docker: otomatis menggunakan http://backend:3000 — tidak perlu diubah
# Override hanya jika ada konfigurasi jaringan khusus:
# BACKEND_SELF_URL=http://192.168.25.64:3000
BACKEND_SELF_URL=


# ── Ngrok — Public Tunnel ─────────────────────────────────────────────────────
# Diperlukan jika Formbricks di cloud dan server di LAN perusahaan
# (Formbricks tidak bisa langsung reach server lokal tanpa tunnel)
#
# Cara setup:
#   1. Daftar gratis di: https://ngrok.com
#   2. Buka: https://dashboard.ngrok.com/get-started/your-authtoken
#   3. Salin authtoken → isi di bawah
#   4. Juga update langsung di file ngrok.yml (untuk production)
#
# Setelah ngrok aktif, ambil URL publik:
#   ./infra/scripts/start-prod.sh ngrok-url
#   Atau buka: http://SERVER_IP:4040
#
# Set URL publik ngrok di Formbricks:
#   Settings → Integrations → Webhooks → Add Webhook
#   URL: https://xxxx.ngrok-free.app/webhook/formbricks
#   Event: Response Finished
#
# CATATAN: URL ngrok berubah setiap restart (akun gratis).
# Untuk URL tetap, gunakan ngrok Pro atau domain sendiri.
NGROK_AUTHTOKEN=your_ngrok_authtoken_here


# ── Formbricks Form IDs ───────────────────────────────────────────────────────
# ID survey Formbricks untuk form Ticketing Support dan Incident Report
#
# Cara mendapatkan Form ID:
#   1. Login ke Formbricks dashboard
#   2. Buka survey yang diinginkan
#   3. Ambil ID dari URL: .../surveys/ID_FORM_INI/...
#
# Jika dikosongkan → sistem menggunakan ID default di backend/src/config/index.js
FORM_ID_TICKETING=your_formbricks_ticketing_form_id
FORM_ID_INCIDENT=your_formbricks_incident_form_id


# ── Formbricks Field Mapping ──────────────────────────────────────────────────
# Formbricks mengirim response dengan field ID acak sebagai key
# (bukan label yang mudah dibaca). Mapping ini mengkonversi ID → label.
#
# Format: "questionId:Label Name,questionId2:Label Name2,..."
# Tidak boleh ada spasi di sekitar tanda koma dan titik dua.
#
# Cara mendapatkan Question ID:
#   1. Login ke Formbricks
#   2. Buka survey → Edit
#   3. Klik setiap question → salin ID dari field properties
#   ATAU
#   4. Kirim test submission → cek log backend:
#      docker logs sis-backend | grep "ID→Label"
#
# ── TICKETING FORM Field Mapping ──────────────────────────────────────────────
# Label yang WAJIB ada (harus sesuai persis, case-sensitive):
#   Reporter Information, Division, No Telepon, Email, ID Device,
#   Ruangan, Lantai, Tanggal & Waktu Pemohon,
#   Type of Support Requested, Issue, Jumlah Barang, Attachment
#
# Contoh (sesuaikan questionId dengan form Anda):
# FORMBRICKS_TICKETING_FIELD_MAP=furan0qd44wk06zh1x7eol86:Reporter Information,wxro33g8v747alp0f5h5rjiu:Division,ubv5h3uuh9lqwgw2rb1xcl0t:No Telepon,q4jlog6h436dwbdqdxoxnhy0:Email,pekxomijpxixcvhkyx1ax0kh:ID Device,q0exb43ez6zw9o5xti6isu4w:Ruangan,u7n6ai5rt0ro8iybkfmle7li:Lantai,ngwljbqzvr6mg1xq33v0zhk5:Tanggal & Waktu Pemohon,j5hge2t3a59uw9zuw0l4s63c:Type of Support Requested,funs3653dc10m0ohm7regqm6:Issue,da2u7brsaabl48ympasqqzik:Jumlah Barang,yxxo8hem0sx6ugmionap8y2k:Attachment
FORMBRICKS_TICKETING_FIELD_MAP=

# ── INCIDENT FORM Field Mapping ────────────────────────────────────────────────
# Label yang WAJIB ada (harus sesuai persis, case-sensitive):
#   Incident Title, Incident Information, Date & Time Incident,
#   Priority Incident, Severity Incident, Suspect Area,
#   Indicated Issue, Attachment
#
# Contoh (sesuaikan questionId dengan form Anda):
# FORMBRICKS_INCIDENT_FIELD_MAP=bsq3gnstra5d40chamn1j7bg:Priority Incident,dw20caznxsng3uprsnxvt5nr:Date & Time Incident,f3r029x47v9su3w173fwn4ki:Severity Incident,j5hge2t3a59uw9zuw0l4s63c:Incident Information,lzwo9voycdeywln54rv68f2q:Indicated Issue,sbt48laul3xtcm3kwggf4tpi:Suspect Area
FORMBRICKS_INCIDENT_FIELD_MAP=