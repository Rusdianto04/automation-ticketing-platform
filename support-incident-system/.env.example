# =============================================================================
# .env.example — Support & Incident System (ROOT / Docker Compose)
#
# File ini adalah TEMPLATE untuk docker-compose.prod.yml.
# Salin dan isi:
#   cp .env.example .env && nano .env
#
# Struktur .env project ini:
#   .env (root)            → variabel untuk docker-compose (DB, port, N8N)
#   apps/backend/.env      → variabel app backend (Discord, SMTP, Groq, dll)
#   apps/frontend/.env     → variabel app frontend (auth, JWT, URL)
# =============================================================================

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Digunakan oleh postgres service, backend, frontend, dan n8n
DB_NAME=formbricks_tickets
DB_USER=formbricks_user
DB_PASSWORD=ganti_password_aman_production

# ── Port Mapping ──────────────────────────────────────────────────────────────
PORT=3000
FRONTEND_PORT=3001

# ── N8N ───────────────────────────────────────────────────────────────────────
# Login dashboard N8N: http://SERVER_IP:5678
N8N_USER=admin
N8N_PASS=ganti_password_n8n_production

# API Key untuk integrasi backend ↔ N8N — harus sama dengan apps/backend/.env
N8N_API_KEY=automation_ticketing01_incident02

# Groq API Key — juga dipakai langsung oleh N8N service
# Daftar gratis: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── Host IP ───────────────────────────────────────────────────────────────────
# IP server LAN atau publik — dipakai untuk WEBHOOK_URL n8n
# Contoh: HOST_IP=192.168.1.100
# Wajib diisi agar N8N webhook bisa diakses dari browser/luar container
HOST_IP=192.168.x.x